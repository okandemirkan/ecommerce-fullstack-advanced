# Secrets - replace these values in the deployment platform; never commit .env.
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=replace_with_a_unique_random_password
POSTGRES_DB=ECommerceDB
JWT_KEY=replace_with_at_least_32_random_bytes
LUCKYPENNY_LICENSE_KEY=replace_with_your_free_community_license_key

# Non-secret application settings
JWT_ISSUER=ECommerceApi
JWT_AUDIENCE=ECommerceUsers
JWT_EXPIRES_IN_MINUTES=240
DEMO_WORKSPACE_LIFETIME_MINUTES=120
APP_PORT=3000

# Public frontend configuration. /api uses the bundled nginx reverse proxy.
VITE_API_URL=/api
